# Sao chép file này thành .env trước khi deploy
# KHÔNG commit file .env thực tế

# Môi trường: dev | staging | prod
APP_ENV=prod
LOG_LEVEL=INFO

# Hugging Face token để pull Qwen3-14B-AWQ + Chatterbox model
# Lấy từ https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------------------
# TTS service (port 9004) — Chatterbox Multilingual 0.5B
# ----------------------------------------------------------------------
TTS_DEVICE=cuda
TTS_DTYPE=fp16
TTS_DEFAULT_VOICE_ID=default
TTS_MAX_TEXT_CHARS=2000
TTS_CHUNK_SIZE_CHARS=300
TTS_CHUNK_SILENCE_MS=50
TTS_CONCURRENCY=1
TTS_INFERENCE_TIMEOUT_S=60
TTS_DEFAULT_EXAGGERATION=0.5
TTS_DEFAULT_CFG_WEIGHT=0.5
TTS_DEFAULT_TEMPERATURE=0.8
TTS_NORMALIZE_NUMBERS=true
TTS_TRIM_SILENCE=true
TTS_TRIM_TOP_DB=35.0
TTS_WARMUP_LANGUAGE=en
TTS_WARMUP_VOICE_ID=default
