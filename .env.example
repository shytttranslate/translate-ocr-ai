# Sao chép file này thành .env trước khi deploy
# KHÔNG commit file .env thực tế

# Môi trường: dev | staging | prod
APP_ENV=dev
LOG_LEVEL=INFO

# Hugging Face token để pull Qwen2.5 weights
# Lấy từ https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxx

# API key pepper — BẮT BUỘC random 32+ ký tự ở prod
# Sinh: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY_PEPPER=replace-this-with-32-bytes-random-pepper-in-prod

# Dev API key seed (chỉ dùng local, không hiệu lực ở prod)
DEV_API_KEY=vbk_live_dev_seed_key_for_local_only_xyz

# Grafana admin password
GRAFANA_PASSWORD=changeme
